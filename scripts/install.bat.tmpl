@echo off
setlocal enabledelayedexpansion

REM ============================================================
REM Klarity - Install desktop shortcut ^& add to PATH
REM ============================================================

set "KLARITY_DIR=%~dp0"
set "KLARITY_EXE=%KLARITY_DIR%klarity.exe"
set "KLARITY_ICON=%KLARITY_DIR%logo.ico"

REM --- Pre-flight checks ---
if not exist "%KLARITY_EXE%" (
    echo ERROR: klarity.exe not found at %KLARITY_EXE%
    pause
    exit /b 1
)

if not exist "%KLARITY_ICON%" (
    echo WARNING: logo.ico not found at %KLARITY_ICON%
)

REM --- Create desktop shortcut ---
echo Creating desktop shortcut...
set "SHORTCUT_PATH=%USERPROFILE%\Desktop\Klarity.lnk"

powershell -Command ^
  "$ws = New-Object -ComObject WScript.Shell; ^
   $sc = $ws.CreateShortcut('%SHORTCUT_PATH%'); ^
   $sc.TargetPath = '%KLARITY_EXE%'; ^
   $sc.WorkingDirectory = '%KLARITY_DIR%'; ^
   $sc.IconLocation = '%KLARITY_ICON%'; ^
   $sc.Description = 'Klarity - Image/Video Restoration Tool'; ^
   $sc.Save()"

REM --- Also create Start Menu shortcut ---
set "STARTMENU=%APPDATA%\Microsoft\Windows\Start Menu\Programs"
if not exist "%STARTMENU%\Klarity" mkdir "%STARTMENU%\Klarity"

powershell -Command ^
  "$ws = New-Object -ComObject WScript.Shell; ^
   $sc = $ws.CreateShortcut('%STARTMENU%\Klarity\Klarity.lnk'); ^
   $sc.TargetPath = '%KLARITY_EXE%'; ^
   $sc.WorkingDirectory = '%KLARITY_DIR%'; ^
   $sc.IconLocation = '%KLARITY_ICON%'; ^
   $sc.Description = 'Klarity - Image/Video Restoration Tool'; ^
   $sc.Save()"

REM --- Add to user PATH ---
echo Adding Klarity to user PATH...
set "PATH_KEY=HKCU\Environment"
set "CURRENT_PATH="

REM Read current user PATH
for /f "tokens=2*" %%A in ('reg query "%PATH_KEY%" /v Path 2^>nul') do set "CURRENT_PATH=%%A"

REM Check if already in PATH
echo %CURRENT_PATH% | findstr /I /C:"%KLARITY_DIR%" >nul 2>&1
if %ERRORLEVEL% EQU 0 (
    echo Klarity directory already in PATH - skipping
) else (
    if defined CURRENT_PATH (
        reg add "%PATH_KEY%" /v Path /t REG_EXPAND_SZ /d "%CURRENT_PATH%;%KLARITY_DIR%" /f >nul 2>&1
    ) else (
        reg add "%PATH_KEY%" /v Path /t REG_EXPAND_SZ /d "%KLARITY_DIR%" /f >nul 2>&1
    )
    echo Added to user PATH
)

REM --- Refresh current session PATH ---
REM Note: New CMD windows will pick up the new PATH automatically.
REM Current terminal needs refresh.

echo.
echo ============================================================
echo  Klarity installed successfully!
echo ============================================================
echo.
echo  Desktop shortcut:  %SHORTCUT_PATH%
echo  Start Menu:         %STARTMENU%\Klarity
echo  PATH:               %KLARITY_DIR%
echo.
echo  Open a NEW command prompt or terminal to use:
echo    klarity info
echo.
echo ============================================================
echo.
pause
